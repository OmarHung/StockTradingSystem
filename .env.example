# 複製成 .env 後填入實際值（.env 已被 gitignore，絕不入版控）
# 也可以全部從 WebUI 的「⚙️ 設定 → 🔑 API 金鑰」填寫，會自動寫入 .env

# FinMind API token（免費註冊 https://finmindtrade.com/，用於法人/融資券/月營收/除權息）
FINMIND_TOKEN=

# Claude API（LLM 分析師/交易員/反思，取得於 https://console.anthropic.com/）
ANTHROPIC_API_KEY=

# 永豐金 shioaji（股價主源 + 排行 + Phase 5 模擬/實盤交易）
# 取得：https://www.sinotrade.com.tw/newweb/PythonAPIKey/
SJ_API_KEY=
SJ_SEC_KEY=
